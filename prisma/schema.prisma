model User {
  id            String    @id @default(cuid())
  name          String? @unique
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  password      String?
  role        Role @default(USER)
  image         String?
  country  String @default("unKnown")
  status UserStatus @default(ACTIVE)
  accounts      Account[]
  favorite Favorite[]
  cart Cart[]
  messages  Message[]
  chatRoom ChatRoom?
  notification Notification[]
  order Order[]
  usedCoupons UserCoupon[] 
  PushToken PushToken[]
  chatBotMessage chatBotMessage[]
  comments      Comment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  mediatorAT  DateTime @default(now())
  @@map("users")
}

model verificationToken {
  id String @id @default(cuid())
  email String
  token String @unique
  expires DateTime

  @@unique([email,token])
}

model forgetPassword {
  id String @id @default(cuid())
  email String
  token String @unique
  expires DateTime

  @@unique([email,token])
}
// chat room
model ChatRoom {
  id          String   @id @default(cuid())
user User @relation(fields: [userId],references: [id], onDelete: Cascade)
  userId String @unique
messages Message[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([userId])
}


// msg 
model Message {
  id          String   @id @default(cuid())
  user User @relation(fields: [userId],references: [id], onDelete: Cascade)
  userId String
  chatRoom ChatRoom @relation(fields: [chatRoomId],references: [id],onDelete: Cascade)
  chatRoomId String
  message String  
  isRead Boolean @default(false)
  isDelivered Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
@@index([chatRoomId, isRead])
@@index([chatRoomId,createdAt])
}

model chatBotMessage {
  id          String   @id @default(cuid())
  message String
  userId String
  user User @relation(fields: [userId],references: [id],onDelete: Cascade)
  sender typeSender 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([userId,createdAt])
}

model GlobalNotifications {
  id          String   @id @default(cuid())
  sender Role @default(ADMIN)  
  title       String
  pushImage       String?
  pushUrl        String?
  description String   
  senderImage  String?
  senderName   String
  opens_count Int  @default(0)
  targetUsers Int @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userNotifications Notification[]
  notificationType NotificationType[] @default([IN_APP]) 
  @@index([createdAt])
}

// 1- admin send noti to globalnoti
// 2- when user open web, front will send request to get noti in normalnoti
//    - in backEnd will compare mediator(mediatorAt) between global and UserModal
//    -- insert notis don't exist in norimalNoti
// 3- when user get / Delete this noti
//    - we update mediator Date to be Date.now()
// global notification => the model which the admin will send notification to it

//  user notification and relations 
model Notification {
  id          String   @id @default(cuid())
  user User @relation(fields: [userId],references: [id], onDelete: Cascade)
  userId String
  globalNotification    GlobalNotifications? @relation(fields: [globalNotificationId], references: [id], onDelete: Cascade)
  globalNotificationId String?
  Sender Role @default(ADMIN)  
  title       String
  description String   
  senderImage  String?
  senderName   String
  isRead Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([userId, isRead])
  @@index([userId, createdAt]) 
}
model Announcement {
  id              String   @id @default(cuid())
  title           String   
  url            String?  
  
  
  backgroundColor String   @default("#000000") 
  textColor       String   @default("rgba(27, 26, 26, 1), 26, 26, 1)")
  
  priority        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

}
model PushToken {
  id        String   @id @default(cuid())
  token     String   @unique
  createdAt DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// لازم اي منتج اعملو لازم اكتب هو يندرج تحت اي قسم 

// catagory & subCategory

model Category {
  id        String     @id @default(cuid())
  name      String
  slug         String      @unique
  image String?
  parentId  String?
  parent    Category?  @relation(name: "SubCategory", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  children  Category[] @relation(name: "SubCategory")
  products  Product[]
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  @@index([parentId])
}

model Product {
  id           String      @id @default(cuid())
  name         String
  description  String?
  price        Int
  image        String
  gallery      String[]
  brand        String?
  rating       Int         @default(5)
  inStock      Boolean     @default(true)
  countStock   Int?
  discount     Int?        @default(0)
  slug         String      @unique
  
  subCategoryId   String
  category     Category    @relation(fields: [subCategoryId], references: [id])

  // العلاقات الأخرى
  gender       Gender[]
  size         Size[]
  comments      Comment[]
  favorite     Favorite[]
  cart         Cart[]
  orderItem    OrderItem[]

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  @@index([subCategoryId, createdAt(sort: Desc)])
  @@index([slug])
}
model Comment {
  id        String   @id @default(cuid())
  content   String
  rating    Int
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([productId])
  @@index([rating, createdAt(sort: Desc)])
}
model Order {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  orderItems OrderItem[] 
  totalAmount Int
  coupon String?     
  status      OrderStatus @default(PENDING_PAYMENT) 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([userId]) 
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  
  quantity  Int      // الكمية من المنتج ده في الطلب ده
  price     Int      // السعر وقت الشراء (عشان لو السعر اتغير في جدول المنتج ميتغيرش هنا)

  @@index([orderId])
  @@index([productId])
}

model Coupon {
  id            String      @id @default(cuid())
  code          String      @unique
  discount      Int         // قيمة الخصم (سواء رقم ثابت أو نسبة)
  isPercentage  Boolean     @default(true)
  expiryDate    DateTime
  usageLimit    Int         @default(1000) // أقصى عدد مرات استخدام للكود ككل
  usedCount     Int         @default(0)
  active        Boolean     @default(true)
  // العلاقة مع الجدول الوسيط
  usedBy        UserCoupon[] 

}

model UserCoupon {
  id            String      @id @default(cuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  couponCode String
  coupon Coupon @relation(fields: [couponCode], references: [id])
  @@unique([userId,couponCode])
}



model Favorite {
  id          String   @id @default(cuid())
  user User @relation(fields: [userId],references: [id],onDelete: Cascade)
  userId String
  
  product Product @relation(fields: [productId],references: [id],onDelete: Cascade)
  productId String
@@unique([userId,productId])
 createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Cart {
  id          String   @id @default(cuid())
quantity  Int
size Size
  user User @relation(fields: [userId],references: [id],onDelete: Cascade)
userId String

  product Product @relation(fields: [productId],references: [id],onDelete: Cascade)
//  لما اعمل انكلود الاي ده يخليني اجيب كل تفاصيل المنتج 
  productId String
@@unique([userId,productId,size])
 createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model Analytics {
  id                Int      @id @default(1) 
  homapageVisits    Int      @default(0)
  productPageVisits Int      @default(0)
  aboutPageVisits   Int      @default(0)
  updatedAt         DateTime @updatedAt
}

model ProductAnalyticsByDay {
  id          Int      @id @default(autoincrement())
  productSlug String
  type        AnalyticsType
  count       Int      @default(0) // العدد اللي انضاف "في اليوم ده"
  createdAt        DateTime 
  updatedAt   DateTime @updatedAt

  @@unique([productSlug, type, createdAt]) 
  @@index([createdAt]) 
}


model ChartAnalytics {
  id          String   @id @default(cuid())
  nameAnalytics AnalyticType  @unique
  chartAnalyticsByMonth ChartAnalyticsByMonth[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model ChartAnalyticsByMonth {
  id          String   @id @default(cuid())
  totalAnalytics Float           

  chartAnalyticsId String
  chartAnalytics ChartAnalytics @relation(fields: [chartAnalyticsId],references: [id],onDelete: Cascade,onUpdate: Cascade)
  ChartAnalyticsByday ChartAnalyticsByday[]
  createdAt   DateTime // هنبعتو في لاريكويست
  updatedAt   DateTime @updatedAt
@@index([chartAnalyticsId, createdAt]) 
@@unique([chartAnalyticsId, createdAt])

}
model ChartAnalyticsByday {
  id          String   @id @default(cuid())
  totalAnalytics Float
  chartAnalyticsByMonthId String
  chartAnalyticsByMonth ChartAnalyticsByMonth @relation(fields: [chartAnalyticsByMonthId],references: [id],onDelete: Cascade,onUpdate: Cascade)
  createdAt   DateTime
  updatedAt   DateTime @updatedAt
@@index([chartAnalyticsByMonthId, createdAt])
@@unique([chartAnalyticsByMonthId, createdAt])
}
