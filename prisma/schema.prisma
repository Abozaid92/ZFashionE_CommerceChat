generator client {
  provider = "prisma-client-js"
  runtime  = "vercel-edge"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")

}


// enums
enum Role { 
  USER
  ADMIN
}
enum UserStatus {
  ACTIVE
  BANNED
}
enum NotificationType {
  IN_APP
  PUSH
  ANNOUNCEMENT_BAR
}
enum typeSender {
  USER
  BOT
}
enum Gender {
  kids
  male
  female
  unisex
}
enum Size {
  Small
  Medium
  Large
  XLarge
}
enum OrderStatus {
  PENDING_PAYMENT
 PROCESSING
  SHIPPED
 DELIVERED
 CANCELLED
  REFUNDED
}

enum AnalyticType {
  USERS
  ORDERS
  REVENUE
  NET_PROFIT
  COMPLAINTS
}

enum AnalyticsType {
  CART
  PURCHASE
}
model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
  role        Role @default(USER)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
  @@map("accounts")
}
 
